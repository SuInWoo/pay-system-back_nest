# Copy this file to .env and fill in values. Do not commit .env.

# Server
PORT=

# CORS 허용 오리진 (쉼표 구분, 미설정 시 http://localhost:3000)
CORS_ORIGINS=

# PostgreSQL (TypeORM)
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT (Auth)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=
JWT_REFRESH_EXPIRES_IN=

# PII 암호화 (주문자명, 주소, 연락처, 이메일)
# 32바이트 base64 키. 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=

# Toss Payments (서버 전용)
TOSS_SECRET_KEY=
TOSS_API_VERSION=2024-06-01

# 웹훅 사용할 때만 필요
TOSS_WEBHOOK_SECRET=
